# Copie este arquivo para .env e preencha os valores reais.
# NUNCA coloque o .env de verdade no controlo de versão.

PORT=3000

# Base de dados MySQL/MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=servcasa

# Chave usada para assinar os tokens de login (JWT). Gere uma bem grande e
# aleatória, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_esta_chave_por_uma_bem_grande_e_secreta

# Origens autorizadas a chamar a API (CORS) — site do cliente, backoffice e app do profissional
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:5175

# URL pública do site do cliente, usada para montar o link de pagamento
# enviado por e-mail após o check-out. Em produção, aponte para o domínio real.
CLIENT_URL=http://localhost:5173

# ─── E-mail (fatura + link de pagamento após o check-out) ──────────────────
# Sem estas variáveis preenchidas, o sistema continua a funcionar
# normalmente — os e-mails só ficam registados no terminal em vez de
# enviados de verdade. Exemplos de serviços compatíveis: Gmail (com senha
# de app), SendGrid, Mailgun, Brevo, Amazon SES, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ServCasa <naoresponder@servcasa.co.mz>"
